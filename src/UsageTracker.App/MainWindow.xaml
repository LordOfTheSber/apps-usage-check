<Window
    x:Class="UsageTracker.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:UsageTracker.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Usage Tracker"
    Width="1080"
    Height="720"
    MinWidth="960"
    MinHeight="600"
    Icon="Assets/app-icon.ico"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="16" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="16" />
      <RowDefinition Height="*" />
      <RowDefinition Height="16" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border
        Grid.Row="0"
        Padding="24"
        Background="{StaticResource SurfaceBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="18">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock
              FontSize="30"
              FontWeight="SemiBold"
              Text="Usage Tracker" />
          <TextBlock
              Margin="0,8,0,0"
              Foreground="{StaticResource SecondaryTextBrush}"
              TextWrapping="Wrap"
              Text="Track running time and foreground time for the apps you care about. Closing this window hides it; use Exit to stop tracking." />
        </StackPanel>

        <StackPanel
            Grid.Column="1"
            Orientation="Horizontal"
            VerticalAlignment="Top">
          <Button
              Margin="0,0,12,0"
              Command="{Binding AddProcessCommand}"
              Content="Add Process"
              Style="{StaticResource PrimaryButtonStyle}" />
          <Button
              Margin="0,0,12,0"
              Command="{Binding OpenSettingsCommand}"
              Content="Settings"
              Style="{StaticResource SecondaryButtonStyle}" />
          <Button
              Command="{Binding ExitCommand}"
              Content="Exit"
              Style="{StaticResource DangerButtonStyle}" />
        </StackPanel>
      </Grid>
    </Border>

    <Border
        Grid.Row="2"
        Padding="18,14"
        Background="{StaticResource SurfaceBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="360" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock
            VerticalAlignment="Center"
            FontWeight="SemiBold"
            Text="Time Range" />

        <controls:DateRangePicker
            Grid.Column="1"
            Margin="12,0,0,0"
            EndDate="{Binding CustomEndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            SelectedPreset="{Binding SelectedPreset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            StartDate="{Binding CustomStartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Column="3"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Foreground="{StaticResource SecondaryTextBrush}"
            Text="Running status stays live; filtered totals refresh from persisted history." />
      </Grid>
    </Border>

    <Grid Grid.Row="4">
      <Border
          Background="{StaticResource SurfaceBrush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="18"
          Padding="8">
        <DataGrid
            x:Name="ProcessesGrid"
            ItemsSource="{Binding Processes}"
            IsReadOnly="True"
            EnableRowVirtualization="True"
            EnableColumnVirtualization="True"
            ScrollViewer.CanContentScroll="True"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling"
            Sorting="OnProcessesGridSorting">
          <DataGrid.RowStyle>
            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
              <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnRowPreviewMouseRightButtonDown" />
              <Setter Property="ContextMenu">
                <Setter.Value>
                  <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem
                        Command="{Binding TogglePauseCommand}"
                        Header="{Binding ActionText}" />
                    <MenuItem
                        Command="{Binding EditCommand}"
                        Header="Edit…" />
                    <Separator />
                    <MenuItem
                        Command="{Binding RemoveCommand}"
                        Header="Remove" />
                  </ContextMenu>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGrid.RowStyle>
          <DataGrid.Columns>
            <DataGridTemplateColumn Width="56" Header="" CanUserSort="False">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse
                        Width="12"
                        Height="12"
                        Fill="{Binding StatusIndicatorState, Converter={StaticResource ProcessItemStatusBrushConverter}}" />
                  </Grid>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn x:Name="ProcessColumn" Width="2.2*" Header="Process" SortMemberPath="Process">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel>
                    <TextBlock
                        FontWeight="SemiBold"
                        Text="{Binding PrimaryName}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        Text="{Binding SecondaryName}" />
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn x:Name="StateColumn" Width="1.1*" Header="State" SortMemberPath="State">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding StateText}" />
                    <Border
                        Margin="8,0,0,0"
                        Padding="8,2"
                        Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding IsForeground, Converter={StaticResource BoolToVisibilityConverter}}">
                      <TextBlock
                          FontSize="11"
                          Foreground="{StaticResource SecondaryTextBrush}"
                          Text="Foreground" />
                    </Border>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTextColumn
                x:Name="RunningTimeColumn"
                Width="1.1*"
                Binding="{Binding DisplayedRunningSeconds, Converter={StaticResource SecondsToTimeStringConverter}}"
                Header="Running Time"
                SortMemberPath="RunningTime" />
            <DataGridTextColumn
                x:Name="ForegroundTimeColumn"
                Width="1.1*"
                Binding="{Binding DisplayedForegroundSeconds, Converter={StaticResource SecondsToTimeStringConverter}}"
                Header="Foreground Time"
                SortMemberPath="ForegroundTime" />

            <DataGridTemplateColumn Width="220" Header="Actions" CanUserSort="False">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <Button
                        Width="92"
                        Margin="0,0,8,0"
                        Command="{Binding TogglePauseCommand}"
                        Content="{Binding ActionText}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                    <Button
                        Width="92"
                        Command="{Binding RemoveCommand}"
                        Content="Remove"
                        Style="{StaticResource DangerButtonStyle}" />
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Border>

      <Border
          Padding="24"
          Background="#CCFFFDF9"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="16"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Visibility="{Binding HasProcesses, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
        <StackPanel Width="420">
          <TextBlock
              FontSize="22"
              FontWeight="SemiBold"
              Text="Nothing tracked yet" />
          <TextBlock
              Margin="0,10,0,0"
              Foreground="{StaticResource SecondaryTextBrush}"
              TextWrapping="Wrap"
              Text="Add a running process from the toolbar, or type a process name manually in the dialog. The list will refresh every second while the engine keeps collecting usage time." />
        </StackPanel>
      </Border>
    </Grid>

    <Border
        Grid.Row="6"
        Padding="18,14"
        Background="{StaticResource SurfaceBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock
              FontWeight="SemiBold"
              Text="{Binding StatusMessage}" />
          <TextBlock
              Margin="0,6,0,0"
              Foreground="{StaticResource SecondaryTextBrush}"
              Text="{Binding LastRefreshedAt, StringFormat=Last refresh: {0:HH:mm:ss}}" />
        </StackPanel>

        <StackPanel
            Grid.Column="1"
            Orientation="Horizontal"
            VerticalAlignment="Center">
          <Border
              Margin="0,0,10,0"
              Padding="10,4"
              Background="{StaticResource SurfaceAltBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="10">
            <StackPanel Orientation="Horizontal">
              <Ellipse
                  Width="10"
                  Height="10"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center"
                  Fill="{Binding DatabaseConnectionState, Converter={StaticResource ConnectionStatusBrushConverter}}" />
              <TextBlock Text="{Binding DatabaseStatusText}" />
            </StackPanel>
          </Border>
          <Border
              Margin="0,0,10,0"
              Padding="10,4"
              Background="{StaticResource SurfaceAltBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="10">
            <TextBlock Text="{Binding TrackedProcessCount, StringFormat=Tracked: {0}}" />
          </Border>
          <Border
              Margin="0,0,10,0"
              Padding="10,4"
              Background="{StaticResource SurfaceAltBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="10">
            <TextBlock Text="{Binding ActiveProcessCount, StringFormat=Active: {0}}" />
          </Border>
          <Border
              Padding="10,4"
              Background="{StaticResource SurfaceAltBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="10">
            <TextBlock Text="{Binding RunningProcessCount, StringFormat=Running now: {0}}" />
          </Border>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
