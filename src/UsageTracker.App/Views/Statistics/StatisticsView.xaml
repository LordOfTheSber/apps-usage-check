<UserControl
    x:Class="UsageTracker.App.Views.Statistics.StatisticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:UsageTracker.App.ViewModels.Statistics"
    xmlns:v="clr-namespace:UsageTracker.App.Views.Statistics"
    mc:Ignorable="d">
  <UserControl.Resources>
    <Style x:Key="SegmentedRadioStyle" TargetType="RadioButton">
      <Setter Property="Margin" Value="3,0" />
      <Setter Property="Padding" Value="14,6" />
      <Setter Property="MinWidth" Value="120" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border
                x:Name="RootBorder"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="{TemplateBinding Padding}"
                MinWidth="{TemplateBinding MinWidth}">
              <ContentPresenter
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="White" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <DataTemplate DataType="{x:Type vm:SummaryCardsViewModel}">
      <v:SummaryCardsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PerProcessTotalsViewModel}">
      <v:PerProcessTotalsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:DailyBreakdownViewModel}">
      <v:DailyBreakdownView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ShareBreakdownViewModel}">
      <v:ShareBreakdownView />
    </DataTemplate>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="14" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
      <RadioButton
          Content="Summary"
          GroupName="StatisticKind"
          IsChecked="{Binding IsSummarySelected, Mode=TwoWay}"
          Style="{StaticResource SegmentedRadioStyle}" />
      <RadioButton
          Content="Per process"
          GroupName="StatisticKind"
          IsChecked="{Binding IsPerProcessSelected, Mode=TwoWay}"
          Style="{StaticResource SegmentedRadioStyle}" />
      <RadioButton
          Content="Daily"
          GroupName="StatisticKind"
          IsChecked="{Binding IsDailySelected, Mode=TwoWay}"
          Style="{StaticResource SegmentedRadioStyle}" />
      <RadioButton
          Content="Share"
          GroupName="StatisticKind"
          IsChecked="{Binding IsShareSelected, Mode=TwoWay}"
          Style="{StaticResource SegmentedRadioStyle}" />
    </StackPanel>

    <ContentControl
        Grid.Row="2"
        Content="{Binding ActiveSubViewModel}" />
  </Grid>
</UserControl>
