<UserControl
    x:Class="UsageTracker.App.Views.Statistics.ShareBreakdownView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
  <Border
      Background="{StaticResource SurfaceBrush}"
      BorderBrush="{StaticResource BorderBrush}"
      BorderThickness="1"
      CornerRadius="14"
      Padding="16">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="12" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <TextBlock
          VerticalAlignment="Center"
          FontWeight="SemiBold"
          Text="Share of running time" />

      <Grid Grid.Row="2">
        <lvc:PieChart
            LegendPosition="Bottom"
            Series="{Binding Series}"
            Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}" />
        <TextBlock
            Margin="0,0,0,48"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource PrimaryTextBrush}"
            IsHitTestVisible="False"
            Text="{Binding TotalLabel}"
            Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}" />
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{StaticResource SecondaryTextBrush}"
            FontSize="14"
            Text="No usage recorded in this range."
            Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}" />
      </Grid>
    </Grid>
  </Border>
</UserControl>
