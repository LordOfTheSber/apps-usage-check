<UserControl
    x:Class="UsageTracker.App.Views.Statistics.SummaryCardsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:UsageTracker.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
  <UserControl.Resources>
    <Style x:Key="CardBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="Margin" Value="6" />
    </Style>
    <Style x:Key="CardCaptionStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="CardPrimaryStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,8,0,0" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="CardSecondaryStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Margin" Value="0,4,0,0" />
    </Style>
  </UserControl.Resources>

  <UniformGrid Columns="3" Margin="-6">
    <Border Style="{StaticResource CardBorderStyle}">
      <StackPanel>
        <TextBlock Style="{StaticResource CardCaptionStyle}" Text="MOST USED" />
        <TextBlock
            Style="{StaticResource CardPrimaryStyle}"
            Text="{Binding MostUsedProcessName}" />
        <TextBlock
            Style="{StaticResource CardSecondaryStyle}"
            Text="{Binding MostUsedSeconds, Converter={StaticResource SecondsToTimeStringConverter}}" />
      </StackPanel>
    </Border>

    <Border Style="{StaticResource CardBorderStyle}">
      <StackPanel>
        <TextBlock Style="{StaticResource CardCaptionStyle}" Text="TOTAL TRACKED" />
        <TextBlock
            Style="{StaticResource CardPrimaryStyle}"
            Text="{Binding TotalTrackedSeconds, Converter={StaticResource SecondsToTimeStringConverter}}" />
        <TextBlock
            Style="{StaticResource CardSecondaryStyle}"
            Text="{Binding ActiveProcessCount, StringFormat='{}{0} active processes'}" />
      </StackPanel>
    </Border>

    <Border Style="{StaticResource CardBorderStyle}">
      <StackPanel>
        <TextBlock Style="{StaticResource CardCaptionStyle}" Text="ACTIVE PROCESSES" />
        <TextBlock
            Style="{StaticResource CardPrimaryStyle}"
            Text="{Binding ActiveProcessCount}" />
        <TextBlock
            Style="{StaticResource CardSecondaryStyle}"
            Text="With usage in this range" />
      </StackPanel>
    </Border>
  </UniformGrid>
</UserControl>
