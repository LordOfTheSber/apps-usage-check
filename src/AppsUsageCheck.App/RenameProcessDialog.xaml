<Window
    x:Class="AppsUsageCheck.App.RenameProcessDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Rename Process"
    Width="520"
    Height="380"
    MinWidth="480"
    MinHeight="340"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="12" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="20" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="8" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="12" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="12" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock
        FontSize="24"
        FontWeight="SemiBold"
        Text="Rename Process" />

    <TextBlock
        Grid.Row="2"
        Foreground="{StaticResource SecondaryTextBrush}"
        TextWrapping="Wrap"
        Text="Update the optional custom label shown in the UI. Leave it blank to use the process name instead." />

    <StackPanel Grid.Row="4">
      <TextBlock
          FontWeight="SemiBold"
          Text="Tracked process" />
      <TextBox
          Margin="0,8,0,0"
          IsReadOnly="True"
          Text="{Binding ProcessName, Mode=OneWay}" />
    </StackPanel>

    <StackPanel Grid.Row="6">
      <TextBlock
          FontWeight="SemiBold"
          Text="Custom name" />
      <TextBox
          Margin="0,8,0,0"
          Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
    </StackPanel>

    <TextBlock
        Grid.Row="8"
        Foreground="{StaticResource SecondaryTextBrush}"
        TextWrapping="Wrap"
        Text="Blank clears the custom name and the list falls back to the normalized process name." />

    <StackPanel
        Grid.Row="11"
        HorizontalAlignment="Right"
        Orientation="Horizontal">
      <Button
          Width="96"
          Margin="0,0,10,0"
          Content="Cancel"
          IsCancel="True"
          Style="{StaticResource SecondaryButtonStyle}" />
      <Button
          Width="112"
          Click="OnSaveClick"
          Content="Save"
          IsDefault="True"
          IsEnabled="{Binding CanSubmit}"
          Style="{StaticResource PrimaryButtonStyle}" />
    </StackPanel>
  </Grid>
</Window>
