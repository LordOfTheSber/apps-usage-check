<Window
    x:Class="AppsUsageCheck.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:coreEnums="clr-namespace:AppsUsageCheck.Core.Enums;assembly=AppsUsageCheck.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Apps Usage Check"
    Width="1080"
    Height="720"
    MinWidth="960"
    MinHeight="600"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="16" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="16" />
      <RowDefinition Height="*" />
      <RowDefinition Height="16" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border
        Grid.Row="0"
        Padding="24"
        Background="{StaticResource SurfaceBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="18">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock
              FontSize="30"
              FontWeight="SemiBold"
              Text="Apps Usage Check" />
          <TextBlock
              Margin="0,8,0,0"
              Foreground="{StaticResource SecondaryTextBrush}"
              TextWrapping="Wrap"
              Text="Track running time and foreground time for the apps you care about. Closing this window hides it; use Exit to stop tracking." />
        </StackPanel>

        <StackPanel
            Grid.Column="1"
            Orientation="Horizontal"
            VerticalAlignment="Top">
          <Button
              Margin="0,0,12,0"
              Command="{Binding AddProcessCommand}"
              Content="Add Process"
              Style="{StaticResource PrimaryButtonStyle}" />
          <Button
              Margin="0,0,12,0"
              Command="{Binding OpenSettingsCommand}"
              Content="Settings"
              Style="{StaticResource SecondaryButtonStyle}" />
          <Button
              Command="{Binding ExitCommand}"
              Content="Exit"
              Style="{StaticResource DangerButtonStyle}" />
        </StackPanel>
      </Grid>
    </Border>

    <Border
        Grid.Row="2"
        Padding="18,14"
        Background="{StaticResource SurfaceBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="220" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="180" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="180" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock
            VerticalAlignment="Center"
            FontWeight="SemiBold"
            Text="Time Range" />

        <ComboBox
            Grid.Column="1"
            Margin="12,0,0,0"
            SelectedValue="{Binding SelectedPreset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            SelectedValuePath="Tag"
            Style="{StaticResource FilterComboBoxStyle}">
          <ComboBoxItem Content="All Time" Tag="{x:Static coreEnums:TimeRangePreset.AllTime}" />
          <ComboBoxItem Content="Today" Tag="{x:Static coreEnums:TimeRangePreset.Today}" />
          <ComboBoxItem Content="Yesterday" Tag="{x:Static coreEnums:TimeRangePreset.Yesterday}" />
          <ComboBoxItem Content="Last 3 Days" Tag="{x:Static coreEnums:TimeRangePreset.Last3Days}" />
          <ComboBoxItem Content="Last 7 Days" Tag="{x:Static coreEnums:TimeRangePreset.Last7Days}" />
          <ComboBoxItem Content="Last 14 Days" Tag="{x:Static coreEnums:TimeRangePreset.Last14Days}" />
          <ComboBoxItem Content="Last 30 Days" Tag="{x:Static coreEnums:TimeRangePreset.Last30Days}" />
          <ComboBoxItem Content="This Week" Tag="{x:Static coreEnums:TimeRangePreset.ThisWeek}" />
          <ComboBoxItem Content="Last Week" Tag="{x:Static coreEnums:TimeRangePreset.LastWeek}" />
          <ComboBoxItem Content="This Month" Tag="{x:Static coreEnums:TimeRangePreset.ThisMonth}" />
          <ComboBoxItem Content="Last Month" Tag="{x:Static coreEnums:TimeRangePreset.LastMonth}" />
          <ComboBoxItem Content="Custom" Tag="{x:Static coreEnums:TimeRangePreset.Custom}" />
        </ComboBox>

        <TextBlock
            Grid.Column="3"
            VerticalAlignment="Center"
            FontWeight="SemiBold"
            Text="From"
            Visibility="{Binding IsCustomRangeSelected, Converter={StaticResource BoolToVisibilityConverter}}" />

        <DatePicker
            Grid.Column="4"
            SelectedDate="{Binding CustomStartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            SelectedDateFormat="Short"
            Visibility="{Binding IsCustomRangeSelected, Converter={StaticResource BoolToVisibilityConverter}}" />

        <DatePicker
            Grid.Column="6"
            SelectedDate="{Binding CustomEndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            SelectedDateFormat="Short"
            Visibility="{Binding IsCustomRangeSelected, Converter={StaticResource BoolToVisibilityConverter}}" />

        <TextBlock
            Grid.Column="7"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Foreground="{StaticResource SecondaryTextBrush}"
            Text="Running status stays live; filtered totals refresh from persisted history." />
      </Grid>
    </Border>

    <Grid Grid.Row="4">
      <Border
          Background="{StaticResource SurfaceBrush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="18"
          Padding="8">
        <DataGrid
            ItemsSource="{Binding Processes}"
            IsReadOnly="True"
            EnableRowVirtualization="True"
            EnableColumnVirtualization="True"
            ScrollViewer.CanContentScroll="True"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling">
          <DataGrid.RowStyle>
            <Style TargetType="DataGridRow">
              <Setter Property="ContextMenu">
                <Setter.Value>
                  <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem
                        Command="{Binding TogglePauseCommand}"
                        Header="{Binding ActionText}" />
                    <MenuItem
                        Command="{Binding EditTimeCommand}"
                        Header="Edit Time" />
                    <Separator />
                    <MenuItem
                        Command="{Binding RemoveCommand}"
                        Header="Remove" />
                  </ContextMenu>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGrid.RowStyle>
          <DataGrid.Columns>
            <DataGridTemplateColumn Width="56" Header="">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse
                        Width="12"
                        Height="12"
                        Fill="{Binding Converter={StaticResource ProcessItemStatusBrushConverter}}" />
                  </Grid>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="2.2*" Header="Process">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel>
                    <TextBlock
                        FontWeight="SemiBold"
                        Text="{Binding PrimaryName}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        Text="{Binding SecondaryName}" />
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="1.1*" Header="State">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding StateText}" />
                    <Border
                        Margin="8,0,0,0"
                        Padding="8,2"
                        Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding IsForeground, Converter={StaticResource BoolToVisibilityConverter}}">
                      <TextBlock
                          FontSize="11"
                          Foreground="{StaticResource SecondaryTextBrush}"
                          Text="Foreground" />
                    </Border>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTextColumn
                Width="1.1*"
                Binding="{Binding DisplayedRunningSeconds, Converter={StaticResource SecondsToTimeStringConverter}}"
                Header="Running Time" />
            <DataGridTextColumn
                Width="1.1*"
                Binding="{Binding DisplayedForegroundSeconds, Converter={StaticResource SecondsToTimeStringConverter}}"
                Header="Foreground Time" />

            <DataGridTemplateColumn Width="220" Header="Actions">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <Button
                        Width="92"
                        Margin="0,0,8,0"
                        Command="{Binding TogglePauseCommand}"
                        Content="{Binding ActionText}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                    <Button
                        Width="92"
                        Command="{Binding RemoveCommand}"
                        Content="Remove"
                        Style="{StaticResource DangerButtonStyle}" />
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Border>

      <Border
          Padding="24"
          Background="#CCFFFDF9"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="16"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Visibility="{Binding HasProcesses, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
        <StackPanel Width="420">
          <TextBlock
              FontSize="22"
              FontWeight="SemiBold"
              Text="Nothing tracked yet" />
          <TextBlock
              Margin="0,10,0,0"
              Foreground="{StaticResource SecondaryTextBrush}"
              TextWrapping="Wrap"
              Text="Add a running process from the toolbar, or type a process name manually in the dialog. The list will refresh every second while the engine keeps collecting usage time." />
        </StackPanel>
      </Border>
    </Grid>

    <Border
        Grid.Row="6"
        Padding="18,14"
        Background="{StaticResource SurfaceBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock
              FontWeight="SemiBold"
              Text="{Binding StatusMessage}" />
          <TextBlock
              Margin="0,6,0,0"
              Foreground="{StaticResource SecondaryTextBrush}"
              Text="{Binding LastRefreshedAt, StringFormat=Last refresh: {0:HH:mm:ss}}" />
        </StackPanel>

        <StackPanel
            Grid.Column="1"
            Orientation="Horizontal"
            VerticalAlignment="Center">
          <Border
              Margin="0,0,10,0"
              Padding="10,4"
              Background="{StaticResource SurfaceAltBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="10">
            <StackPanel Orientation="Horizontal">
              <Ellipse
                  Width="10"
                  Height="10"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center"
                  Fill="{Binding DatabaseConnectionState, Converter={StaticResource ConnectionStatusBrushConverter}}" />
              <TextBlock Text="{Binding DatabaseStatusText}" />
            </StackPanel>
          </Border>
          <Border
              Margin="0,0,10,0"
              Padding="10,4"
              Background="{StaticResource SurfaceAltBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="10">
            <TextBlock Text="{Binding TrackedProcessCount, StringFormat=Tracked: {0}}" />
          </Border>
          <Border
              Margin="0,0,10,0"
              Padding="10,4"
              Background="{StaticResource SurfaceAltBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="10">
            <TextBlock Text="{Binding ActiveProcessCount, StringFormat=Active: {0}}" />
          </Border>
          <Border
              Padding="10,4"
              Background="{StaticResource SurfaceAltBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="10">
            <TextBlock Text="{Binding RunningProcessCount, StringFormat=Running now: {0}}" />
          </Border>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
