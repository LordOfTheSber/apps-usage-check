<Window
    x:Class="AppsUsageCheck.App.EditTimeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edit Time"
    Width="620"
    Height="700"
    MinWidth="580"
    MinHeight="660"
    WindowStartupLocation="CenterOwner">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="10" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="20" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="18" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="18" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="16" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="12" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="12" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock
        FontSize="24"
        FontWeight="SemiBold"
        Text="Edit Time" />

    <TextBlock
        Grid.Row="2"
        Foreground="{StaticResource SecondaryTextBrush}"
        TextWrapping="Wrap">
      <Run Text="Create an append-only audit entry for " />
      <Run FontWeight="SemiBold" Text="{Binding ProcessLabel, Mode=OneWay}" />
      <Run Text=". Existing sessions stay unchanged." />
    </TextBlock>

    <Grid Grid.Row="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border
          Padding="16"
          Background="{StaticResource SurfaceBrush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="14">
        <StackPanel>
          <TextBlock
              Foreground="{StaticResource SecondaryTextBrush}"
              Text="Current running time" />
          <TextBlock
              Margin="0,8,0,0"
              FontSize="22"
              FontWeight="SemiBold"
              Text="{Binding CurrentRunningSeconds, Converter={StaticResource SecondsToTimeStringConverter}}" />
        </StackPanel>
      </Border>

      <Border
          Grid.Column="2"
          Padding="16"
          Background="{StaticResource SurfaceBrush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="14">
        <StackPanel>
          <TextBlock
              Foreground="{StaticResource SecondaryTextBrush}"
              Text="Current foreground time" />
          <TextBlock
              Margin="0,8,0,0"
              FontSize="22"
              FontWeight="SemiBold"
              Text="{Binding CurrentForegroundSeconds, Converter={StaticResource SecondsToTimeStringConverter}}" />
        </StackPanel>
      </Border>
    </Grid>

    <Border
        Grid.Row="6"
        Padding="18"
        Background="{StaticResource SurfaceBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="10" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
          <TextBlock
              FontWeight="SemiBold"
              Text="Target" />
          <ComboBox
              Margin="0,8,0,0"
              DisplayMemberPath="Label"
              ItemsSource="{Binding TargetOptions}"
              SelectedItem="{Binding SelectedTargetOption, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Grid.Column="2">
          <TextBlock
              FontWeight="SemiBold"
              Text="Operation" />
          <ComboBox
              Margin="0,8,0,0"
              DisplayMemberPath="Label"
              ItemsSource="{Binding OperationOptions}"
              SelectedItem="{Binding SelectedOperationOption, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
          <TextBlock
              FontWeight="SemiBold"
              Text="Adjustment" />
          <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox
                Grid.Column="0"
                Text="{Binding HoursText, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox
                Grid.Column="2"
                Text="{Binding MinutesText, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox
                Grid.Column="4"
                Text="{Binding SecondsText, UpdateSourceTrigger=PropertyChanged}" />
          </Grid>

          <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Foreground="{StaticResource SecondaryTextBrush}"
                Text="Hours" />
            <TextBlock
                Grid.Column="2"
                Foreground="{StaticResource SecondaryTextBrush}"
                Text="Minutes" />
            <TextBlock
                Grid.Column="4"
                Foreground="{StaticResource SecondaryTextBrush}"
                Text="Seconds" />
          </Grid>
        </StackPanel>
      </Grid>
    </Border>

    <Border
        Grid.Row="8"
        Padding="18"
        Background="#CCFFFDF9"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="10" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Foreground="{StaticResource SecondaryTextBrush}"
            Text="{Binding SelectedTargetLabel, StringFormat=Current {0}}" />
        <TextBlock
            Grid.Column="1"
            Margin="14,0,0,0"
            FontWeight="SemiBold"
            Text="{Binding CurrentSelectedTotalSeconds, Converter={StaticResource SecondsToTimeStringConverter}}" />

        <TextBlock
            Grid.Row="2"
            Foreground="{StaticResource SecondaryTextBrush}"
            Text="Adjustment" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="1"
            Margin="14,0,0,0"
            FontWeight="SemiBold"
            Text="{Binding SignedAdjustmentDisplayText}" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="2"
            Margin="18,0,0,0"
            Foreground="{StaticResource SecondaryTextBrush}"
            Text="{Binding PreviewTotalSeconds, Converter={StaticResource SecondsToTimeStringConverter}, StringFormat=Preview: {0}}" />
      </Grid>
    </Border>

    <StackPanel Grid.Row="10">
      <TextBlock
          FontWeight="SemiBold"
          Text="Reason (optional)" />
      <TextBox
          Margin="0,8,0,0"
          Height="90"
          AcceptsReturn="True"
          TextWrapping="Wrap"
          VerticalScrollBarVisibility="Auto"
          Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" />
    </StackPanel>

    <StackPanel Grid.Row="12">
      <TextBlock
          Foreground="{StaticResource SecondaryTextBrush}"
          TextWrapping="Wrap"
          Text="Subtractions cannot go below zero, and foreground time cannot exceed running time." />
      <TextBlock
          Margin="0,8,0,0"
          Foreground="{StaticResource DangerBrush}"
          TextWrapping="Wrap"
          Text="{Binding ValidationMessage}"
          Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVisibilityConverter}}" />
    </StackPanel>

    <StackPanel
        Grid.Row="15"
        HorizontalAlignment="Right"
        Orientation="Horizontal">
      <Button
          Width="96"
          Margin="0,0,10,0"
          Content="Cancel"
          IsCancel="True"
          Style="{StaticResource SecondaryButtonStyle}" />
      <Button
          Width="128"
          Click="OnSaveClick"
          Content="Save Adjustment"
          IsDefault="True"
          IsEnabled="{Binding CanSubmit}"
          Style="{StaticResource PrimaryButtonStyle}" />
    </StackPanel>
  </Grid>
</Window>
