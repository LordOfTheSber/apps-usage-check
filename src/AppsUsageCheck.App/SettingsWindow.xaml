<Window
    x:Class="AppsUsageCheck.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    Width="520"
    Height="500"
    MinWidth="480"
    MinHeight="480"
    Icon="Assets/app-icon.ico"
    WindowStartupLocation="CenterOwner">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="10" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="18" />
      <RowDefinition Height="*" />
      <RowDefinition Height="20" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock
        FontSize="24"
        FontWeight="SemiBold"
        Text="Settings" />

    <TextBlock
        Grid.Row="2"
        Foreground="{StaticResource SecondaryTextBrush}"
        TextWrapping="Wrap"
        Text="Update startup behavior and the appsettings-backed tracking, database, and logging values. Non auto-start changes apply after the next restart." />

    <Border
        Grid.Row="4"
        Padding="18"
        Background="{StaticResource SurfaceBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="160" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="16" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="16" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="16" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="16" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="12" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            VerticalAlignment="Center"
            FontWeight="SemiBold"
            Text="Startup" />
        <StackPanel Grid.Column="1">
          <CheckBox
              FontSize="15"
              FontWeight="SemiBold"
              IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
              Content="Start with Windows" />
          <TextBlock
              Margin="0,8,0,0"
              Foreground="{StaticResource SecondaryTextBrush}"
              TextWrapping="Wrap"
              Text="Windows launches Apps Usage Check with the --minimized flag so tracking resumes in the tray." />
        </StackPanel>

        <TextBlock
            Grid.Row="2"
            VerticalAlignment="Center"
            FontWeight="SemiBold"
            Text="Polling (ms)" />
        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            Text="{Binding PollingIntervalMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="4"
            VerticalAlignment="Center"
            FontWeight="SemiBold"
            Text="Flush (sec)" />
        <TextBox
            Grid.Row="4"
            Grid.Column="1"
            Text="{Binding FlushIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="6"
            VerticalAlignment="Center"
            FontWeight="SemiBold"
            Text="Log level" />
        <ComboBox
            Grid.Row="6"
            Grid.Column="1"
            ItemsSource="{Binding AvailableLogLevels}"
            SelectedItem="{Binding MinimumLogLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Style="{StaticResource FilterComboBoxStyle}" />

        <TextBlock
            Grid.Row="8"
            VerticalAlignment="Top"
            FontWeight="SemiBold"
            Text="Connection string" />
        <TextBox
            Grid.Row="8"
            Grid.Column="1"
            MinHeight="84"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto"
            Text="{Binding ConnectionString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="10"
            Grid.ColumnSpan="2"
            Foreground="{StaticResource SecondaryTextBrush}"
            TextWrapping="Wrap"
            Text="Tracking interval, flush interval, connection string, and log level are stored in appsettings.json in the app folder." />
      </Grid>
    </Border>

    <StackPanel
        Grid.Row="6"
        HorizontalAlignment="Right"
        Orientation="Horizontal">
      <Button
          Width="90"
          Margin="0,0,10,0"
          IsCancel="True"
          Content="Cancel"
          Style="{StaticResource SecondaryButtonStyle}" />
      <Button
          Width="90"
          IsDefault="True"
          Click="OnSaveClick"
          Content="Save"
          Style="{StaticResource PrimaryButtonStyle}" />
    </StackPanel>
  </Grid>
</Window>
