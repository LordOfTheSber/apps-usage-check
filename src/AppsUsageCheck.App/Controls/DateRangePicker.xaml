<UserControl
    x:Class="AppsUsageCheck.App.Controls.DateRangePicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">
  <UserControl.Resources>
    <Style x:Key="RangeTriggerStyle" TargetType="ToggleButton">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="MinHeight" Value="42" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border
                x:Name="RootBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="10"
                SnapsToDevicePixels="True">
              <ContentPresenter
                  Margin="14,9"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="RootBorder" Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PresetListBoxStyle" TargetType="ListBox">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="PresetListBoxItemStyle" TargetType="ListBoxItem">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border
                x:Name="PresetBorder"
                Padding="12,10"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="PresetBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="PresetBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="PresetBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="White" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Grid>
    <ToggleButton
        x:Name="TriggerButton"
        MinWidth="320"
        IsChecked="{Binding IsDropDownOpen, ElementName=Root, Mode=TwoWay}"
        Style="{StaticResource RangeTriggerStyle}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock
              FontWeight="SemiBold"
              Text="{Binding ButtonText, ElementName=Root}" />
          <TextBlock
              Margin="0,2,0,0"
              FontSize="11"
              Foreground="{StaticResource SecondaryTextBrush}"
              Text="Quick ranges or a custom calendar selection" />
        </StackPanel>

        <TextBlock
            Grid.Column="1"
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            FontSize="14"
            Text="v" />
      </Grid>
    </ToggleButton>

    <Popup
        AllowsTransparency="True"
        IsOpen="{Binding IsDropDownOpen, ElementName=Root, Mode=TwoWay}"
        Placement="Bottom"
        PlacementTarget="{Binding ElementName=TriggerButton}"
        PopupAnimation="Fade"
        StaysOpen="False">
      <Border
          Width="560"
          Margin="0,8,0,0"
          Padding="18"
          Background="{StaticResource SurfaceBrush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="18"
          SnapsToDevicePixels="True">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <TextBlock
                FontWeight="SemiBold"
                Text="Quick Ranges" />
            <TextBlock
                Margin="0,4,0,14"
                FontSize="11"
                Foreground="{StaticResource SecondaryTextBrush}"
                Text="Pick a preset or switch to a custom range." />

            <ListBox
                ItemContainerStyle="{StaticResource PresetListBoxItemStyle}"
                ItemsSource="{Binding PresetOptions, ElementName=Root}"
                SelectedValue="{Binding SelectedPreset, ElementName=Root, Mode=TwoWay}"
                SelectedValuePath="Value"
                SelectionChanged="PresetListBox_SelectionChanged"
                Style="{StaticResource PresetListBoxStyle}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>

          <StackPanel Grid.Column="2">
            <TextBlock
                FontWeight="SemiBold"
                Text="Custom Range" />
            <TextBlock
                Margin="0,4,0,0"
                Foreground="{StaticResource SecondaryTextBrush}"
                Text="{Binding SelectionSummary, ElementName=Root}" />
            <TextBlock
                Margin="0,10,0,0"
                FontSize="11"
                Foreground="{StaticResource SecondaryTextBrush}"
                TextWrapping="Wrap"
                Text="Click a start date and then an end date to create a custom range. Selecting dates switches the filter to Custom." />

            <Border
                Margin="0,14,0,0"
                Padding="10"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
              <Calendar
                  x:Name="RangeCalendar"
                  SelectedDatesChanged="RangeCalendar_SelectedDatesChanged"
                  SelectionMode="SingleRange" />
            </Border>
          </StackPanel>
        </Grid>
      </Border>
    </Popup>
  </Grid>
</UserControl>
