<Window
    x:Class="AppsUsageCheck.App.EditProcessDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edit Process"
    Width="660"
    Height="800"
    MinWidth="600"
    MinHeight="640"
    WindowStartupLocation="CenterOwner">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="10" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="20" />
      <RowDefinition Height="*" />
      <RowDefinition Height="12" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="16" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock
        FontSize="24"
        FontWeight="SemiBold"
        Text="Edit Process" />

    <TextBlock
        Grid.Row="2"
        Foreground="{StaticResource SecondaryTextBrush}"
        TextWrapping="Wrap">
      <Run Text="Update " />
      <Run FontWeight="SemiBold" Text="{Binding ProcessLabel, Mode=OneWay}" />
      <Run Text=". Display name changes are immediate; time adjustments append an audit entry." />
    </TextBlock>

    <ScrollViewer
        Grid.Row="4"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <Border
            Padding="18"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="14" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="14" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="8" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Text="Display name" />

            <StackPanel Grid.Row="2">
              <TextBlock
                  FontWeight="SemiBold"
                  Text="Tracked process" />
              <TextBox
                  Margin="0,8,0,0"
                  IsReadOnly="True"
                  Text="{Binding RenameSection.ProcessName, Mode=OneWay}" />
            </StackPanel>

            <StackPanel Grid.Row="4">
              <TextBlock
                  FontWeight="SemiBold"
                  Text="Custom name" />
              <TextBox
                  Margin="0,8,0,0"
                  Text="{Binding RenameSection.DisplayName, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <TextBlock
                Grid.Row="6"
                Foreground="{StaticResource SecondaryTextBrush}"
                TextWrapping="Wrap"
                Text="Leave blank to fall back to the process name." />
          </Grid>
        </Border>

        <Border
            Margin="0,16,0,0"
            Padding="18"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="14" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="16" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="16" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="14" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Text="Adjust tracked time" />

            <Grid Grid.Row="2">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Border
                  Padding="14"
                  Background="White"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="12">
                <StackPanel>
                  <TextBlock
                      Foreground="{StaticResource SecondaryTextBrush}"
                      Text="Current running time" />
                  <TextBlock
                      Margin="0,6,0,0"
                      FontSize="20"
                      FontWeight="SemiBold"
                      Text="{Binding TimeSection.CurrentRunningSeconds, Converter={StaticResource SecondsToTimeStringConverter}}" />
                </StackPanel>
              </Border>

              <Border
                  Grid.Column="2"
                  Padding="14"
                  Background="White"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="12">
                <StackPanel>
                  <TextBlock
                      Foreground="{StaticResource SecondaryTextBrush}"
                      Text="Current foreground time" />
                  <TextBlock
                      Margin="0,6,0,0"
                      FontSize="20"
                      FontWeight="SemiBold"
                      Text="{Binding TimeSection.CurrentForegroundSeconds, Converter={StaticResource SecondsToTimeStringConverter}}" />
                </StackPanel>
              </Border>
            </Grid>

            <Grid Grid.Row="4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel>
                <TextBlock
                    FontWeight="SemiBold"
                    Text="Target" />
                <ComboBox
                    Margin="0,8,0,0"
                    DisplayMemberPath="Label"
                    ItemsSource="{Binding TimeSection.TargetOptions}"
                    SelectedItem="{Binding TimeSection.SelectedTargetOption, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock
                    FontWeight="SemiBold"
                    Text="Operation" />
                <ComboBox
                    Margin="0,8,0,0"
                    DisplayMemberPath="Label"
                    ItemsSource="{Binding TimeSection.OperationOptions}"
                    SelectedItem="{Binding TimeSection.SelectedOperationOption, Mode=TwoWay}" />
              </StackPanel>
            </Grid>

            <StackPanel Grid.Row="6">
              <TextBlock
                  FontWeight="SemiBold"
                  Text="Adjustment" />
              <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    Text="{Binding TimeSection.HoursText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    Grid.Column="2"
                    Text="{Binding TimeSection.MinutesText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    Grid.Column="4"
                    Text="{Binding TimeSection.SecondsText, UpdateSourceTrigger=PropertyChanged}" />
              </Grid>

              <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    Text="Hours" />
                <TextBlock
                    Grid.Column="2"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    Text="Minutes" />
                <TextBlock
                    Grid.Column="4"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    Text="Seconds" />
              </Grid>
            </StackPanel>

            <Border
                Grid.Row="8"
                Padding="14"
                Background="#CCFFFDF9"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Foreground="{StaticResource SecondaryTextBrush}"
                    Text="{Binding TimeSection.SelectedTargetLabel, StringFormat=Current {0}}" />
                <TextBlock
                    Grid.Column="1"
                    Margin="14,0,0,0"
                    FontWeight="SemiBold"
                    Text="{Binding TimeSection.CurrentSelectedTotalSeconds, Converter={StaticResource SecondsToTimeStringConverter}}" />

                <TextBlock
                    Grid.Row="2"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    Text="Adjustment" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="14,0,0,0"
                    FontWeight="SemiBold"
                    Text="{Binding TimeSection.SignedAdjustmentDisplayText}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="18,0,0,0"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    Text="{Binding TimeSection.PreviewTotalSeconds, Converter={StaticResource SecondsToTimeStringConverter}, StringFormat=Preview: {0}}" />
              </Grid>
            </Border>
          </Grid>
        </Border>

        <StackPanel Margin="0,16,0,0">
          <TextBlock
              FontWeight="SemiBold"
              Text="Reason (optional)" />
          <TextBox
              Margin="0,8,0,0"
              Height="80"
              AcceptsReturn="True"
              TextWrapping="Wrap"
              VerticalScrollBarVisibility="Auto"
              Text="{Binding TimeSection.Reason, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="6">
      <TextBlock
          Foreground="{StaticResource SecondaryTextBrush}"
          TextWrapping="Wrap"
          Text="Subtractions cannot go below zero, and foreground time cannot exceed running time." />
      <TextBlock
          Margin="0,8,0,0"
          Foreground="{StaticResource DangerBrush}"
          TextWrapping="Wrap"
          Text="{Binding TimeSection.ValidationMessage}"
          Visibility="{Binding TimeSection.HasValidationError, Converter={StaticResource BoolToVisibilityConverter}}" />
    </StackPanel>

    <StackPanel
        Grid.Row="8"
        HorizontalAlignment="Right"
        Orientation="Horizontal">
      <Button
          Width="96"
          Margin="0,0,10,0"
          Content="Cancel"
          IsCancel="True"
          Style="{StaticResource SecondaryButtonStyle}" />
      <Button
          Width="128"
          Click="OnSaveClick"
          Content="Save Changes"
          IsDefault="True"
          IsEnabled="{Binding CanSubmit}"
          Style="{StaticResource PrimaryButtonStyle}" />
    </StackPanel>
  </Grid>
</Window>
