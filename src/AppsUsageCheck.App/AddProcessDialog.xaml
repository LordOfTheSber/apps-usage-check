<Window
    x:Class="AppsUsageCheck.App.AddProcessDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Process"
    Width="560"
    Height="620"
    MinWidth="520"
    MinHeight="560"
    Icon="Assets/app-icon.ico"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="12" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="18" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="8" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="12" />
      <RowDefinition Height="*" />
      <RowDefinition Height="12" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="8" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="20" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock
        FontSize="24"
        FontWeight="SemiBold"
        Text="Add Process" />

    <TextBlock
        Grid.Row="2"
        Foreground="{StaticResource SecondaryTextBrush}"
        TextWrapping="Wrap"
        Text="Pick a currently running process, or enter a process name manually. Names are normalized without the .exe suffix." />

    <TextBlock
        Grid.Row="4"
        FontWeight="SemiBold"
        Text="Search running processes" />

    <TextBox
        Grid.Row="6"
        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

    <ListBox
        Grid.Row="8"
        ItemsSource="{Binding FilteredProcesses}"
        SelectedItem="{Binding SelectedProcessName, Mode=TwoWay}" />

    <TextBlock
        Grid.Row="10"
        FontWeight="SemiBold"
        Text="Manual process name" />

    <TextBox
        Grid.Row="12"
        Text="{Binding ManualProcessName, UpdateSourceTrigger=PropertyChanged}" />

    <StackPanel Grid.Row="14">
      <TextBlock
          FontWeight="SemiBold"
          Text="Display name (optional)" />
      <TextBox
          Margin="0,8,0,0"
          Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />

      <TextBlock
          Margin="0,10,0,0"
          Foreground="{StaticResource SecondaryTextBrush}"
          Text="{Binding ResolvedProcessName, StringFormat=Will track: {0}}" />

      <StackPanel
          Margin="0,18,0,0"
          HorizontalAlignment="Right"
          Orientation="Horizontal">
        <Button
            Width="90"
            Margin="0,0,10,0"
            IsCancel="True"
            Content="Cancel"
            Style="{StaticResource SecondaryButtonStyle}" />
        <Button
            Width="120"
            IsDefault="True"
            Click="OnAddClick"
            Content="Add Process"
            IsEnabled="{Binding CanSubmit}"
            Style="{StaticResource PrimaryButtonStyle}" />
      </StackPanel>
    </StackPanel>
  </Grid>
</Window>
